# =============================================================
#  Repo-root environment variables — consumed by docker-compose
# =============================================================
# Copy this file to .env (gitignored) and fill in real values.
# .env is read automatically by docker-compose at container startup.
#
# Every variable here has a default in docker-compose.yml; copying
# this file is only required when you need to override a default
# (e.g. point at a real Anthropic key or a non-localhost deploy URL).

# ── Keycloak service-account client secret ───────────────────
# Secret for the myproperty-api Keycloak client (service accounts enabled).
# The backend uses client_credentials with this secret to call the Keycloak
# Admin REST API (create users, assign roles). The same value is seeded into
# the realm import so prod and dev stay in sync. Use a random 32+ char value
# in production (e.g. openssl rand -hex 32).
MYPROPERTY_API_CLIENT_SECRET=dev-api-client-secret

# ── Google OAuth (Keycloak IdP federation) ───────────────────
# Obtain from Google Cloud Console: https://console.cloud.google.com
#   APIs & Services > Credentials > Create Credentials > OAuth 2.0 Client ID
#   Application type: Web application
#   Authorized redirect URI:
#     http://localhost:8080/realms/MyProperty/broker/google/endpoint
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# ── Public URLs (used by both frontend build-time and backend issuer) ──
# These are the URLs the BROWSER uses to reach each service. The
# backend container reaches Keycloak via the cluster-internal hostname
# (http://keycloak:8080) — see Keycloak__MetadataAddress in docker-compose.yml.
# Override these when running the stack on a hostname other than localhost.
FRONTEND_PUBLIC_URL=http://localhost:3000
KEYCLOAK_PUBLIC_URL=http://localhost:8080

# MYPROPERTY_FRONTEND_BASE_URL is consumed by keycloak-realm-init to
# render the realm template (redirectUris, webOrigins). Set this when
# Keycloak should issue tokens for a non-localhost frontend.
MYPROPERTY_FRONTEND_BASE_URL=http://localhost:3000

# ── Frontend build-time NEXT_PUBLIC_* (baked into the JS bundle) ──
# Changing any of these requires rebuilding the frontend image:
#   docker compose build frontend
# NEXT_PUBLIC_KEYCLOAK_URL defaults to KEYCLOAK_PUBLIC_URL — override only if they differ.
NEXT_PUBLIC_API_BASE_URL=http://localhost:5042
NEXT_PUBLIC_KEYCLOAK_REALM=MyProperty
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=myproperty-frontend

# ── Anthropic (receipt OCR + AIOps triage) ───────────────────
# Optional in dev. Used by two consumers:
#   - Backend OCR (M3.10): receipt extraction. Disabled if empty.
#   - AIOps webhook (M4.11): alert triage. Falls back to a raw-label
#     dump posted to Slack/stdout if empty — the demo still works.
ANTHROPIC_API_KEY=

# ── AIOps webhook (M4.11) ────────────────────────────────────
# Slack incoming webhook URL (https://hooks.slack.com/services/...).
# Leave empty in dev — the aiops-webhook service then logs Slack
# message bodies to stdout instead. Promtail forwards stdout to Loki,
# so the demo flow is still visible in Grafana → Explore → Loki.
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Anthropic model used by the aiops-webhook for alert triage. Defaults
# to Haiku 4.5 — cheap + fast, appropriate for routine ops triage.
# Override to a Sonnet/Opus snapshot for richer analysis during a
# specific incident.
AIOPS_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Log verbosity for the aiops-webhook service. DEBUG | INFO | WARNING.
AIOPS_LOG_LEVEL=INFO

# Per-call timeouts (seconds) for the aiops-webhook. Defaults are sensible
# for Haiku 4.5 + Slack incoming webhook latency; tighten only if the
# background-task queue is backing up in a high-volume burst.
AIOPS_CLAUDE_TIMEOUT_SECONDS=15
AIOPS_SLACK_TIMEOUT_SECONDS=10

# ── Uptime Kuma (M4.6) ───────────────────────────────────────
# Self-hosted uptime monitor + public status page. Always-on in the
# compose stack; the seed sidecar (`uptime-kuma-init`) bootstraps the
# admin user, the monitors, and the status page on first start.
#
# Admin password — MUST be at least 10 characters (Kuma's own setup
# validator rejects shorter passwords). The default below is a safe
# placeholder for local dev; override before exposing the host port.
KUMA_ADMIN_USERNAME=admin
KUMA_ADMIN_PASSWORD=changeme-please-1234

# Public URL the status page advertises in its footer. The compose
# default points at the host-port binding (3002 → container 3001).
# .env.proxy.example overrides to https://status.${MYPROPERTY_DOMAIN}
# when the nginx reverse proxy is in front.
KUMA_PUBLIC_URL=http://localhost:3002

# Email notification channel — points at the MailHog SMTP catcher
# already in the stack. Test emails land in http://localhost:8025.
# Leave KUMA_SMTP_HOST empty to skip the email channel entirely; the
# seed sidecar then registers only the Slack channel (or neither, when
# both SLACK_WEBHOOK_URL and KUMA_SMTP_HOST are empty).
KUMA_SMTP_HOST=mailhog
KUMA_SMTP_PORT=1025
KUMA_SMTP_FROM=uptime@myproperty.local
KUMA_SMTP_TO=oncall@myproperty.local

# Log verbosity for the seed sidecar. DEBUG | INFO | WARNING.
KUMA_LOG_LEVEL=INFO

# ── Nginx + Let's Encrypt (M4.9, proxy profile) ──────────────────
# Only consumed when running with `docker compose --profile proxy up`.
# See docs/operations/nginx-ssl.md for the end-to-end recipe, and
# .env.proxy.example for an opinionated overlay that also adjusts
# FRONTEND_PUBLIC_URL / KEYCLOAK_PUBLIC_URL / NEXT_PUBLIC_API_BASE_URL /
# MYPROPERTY_FRONTEND_BASE_URL to the proxied https URLs.
#
# Base domain the proxy serves three subdomains under (app.${DOMAIN},
# api.${DOMAIN}, auth.${DOMAIN}). For local dev `myproperty.localhost`
# is a safe default — /etc/hosts entries are still required so the
# subdomains resolve to 127.0.0.1.
MYPROPERTY_DOMAIN=myproperty.localhost

# Contact address Let's Encrypt sends expiry notifications to. Required
# by `init-letsencrypt.sh`; unused in the self-signed dev path.
LETSENCRYPT_EMAIL=admin@example.com
