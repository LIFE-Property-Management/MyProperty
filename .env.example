# =============================================================
#  Repo-root environment variables — consumed by docker-compose
# =============================================================
# Copy this file to .env (gitignored) and fill in real values.
# .env is read automatically by docker-compose at container startup.
#
# Every variable here has a default in docker-compose.yml; copying
# this file is only required when you need to override a default
# (e.g. point at a real Anthropic key or a non-localhost deploy URL).

# ── Google OAuth (Keycloak IdP federation) ───────────────────
# Obtain from Google Cloud Console: https://console.cloud.google.com
#   APIs & Services > Credentials > Create Credentials > OAuth 2.0 Client ID
#   Application type: Web application
#   Authorized redirect URI:
#     http://localhost:8080/realms/MyProperty/broker/google/endpoint
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# ── Public URLs (used by both frontend build-time and backend issuer) ──
# These are the URLs the BROWSER uses to reach each service. The
# backend container reaches Keycloak via the cluster-internal hostname
# (http://keycloak:8080) — see Keycloak__MetadataAddress in docker-compose.yml.
# Override these when running the stack on a hostname other than localhost.
FRONTEND_PUBLIC_URL=http://localhost:3000
KEYCLOAK_PUBLIC_URL=http://localhost:8080

# MYPROPERTY_FRONTEND_BASE_URL is consumed by keycloak-realm-init to
# render the realm template (redirectUris, webOrigins). Set this when
# Keycloak should issue tokens for a non-localhost frontend.
MYPROPERTY_FRONTEND_BASE_URL=http://localhost:3000

# ── Frontend build-time NEXT_PUBLIC_* (baked into the JS bundle) ──
# Changing any of these requires rebuilding the frontend image:
#   docker compose build frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:5042
NEXT_PUBLIC_KEYCLOAK_REALM=MyProperty
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=myproperty-frontend

# ── Anthropic (receipt OCR) ──────────────────────────────────
# Optional in dev — leave empty to disable OCR. M3.10 deliverable.
ANTHROPIC_API_KEY=
