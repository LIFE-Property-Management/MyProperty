# =============================================================
#  Overlay for the M4.9 nginx + SSL reverse proxy (proxy profile)
# =============================================================
# Copy this file to .env (or `cat >> .env`) when running the stack
# behind the nginx reverse proxy:
#
#   ./infrastructure/nginx/init-selfsigned.sh
#   docker compose --profile proxy up -d --build
#
# Without these overrides, the frontend bundle is built with
# http://localhost:* URLs and the browser can't reach the API or
# Keycloak through the proxy (CORS + Keycloak redirect URI mismatch).
#
# A clean clone needs all .env.example variables + everything below.

# ── Proxy hostnames ──────────────────────────────────────────────
# The domain the nginx vhost template substitutes into server_name.
# Four subdomains are served: app.${DOMAIN}, api.${DOMAIN},
# auth.${DOMAIN}, status.${DOMAIN}. Add the same four to your
# /etc/hosts (or the Windows equivalent at
# %WINDIR%\System32\drivers\etc\hosts):
#   127.0.0.1  app.myproperty.localhost
#   127.0.0.1  api.myproperty.localhost
#   127.0.0.1  auth.myproperty.localhost
#   127.0.0.1  status.myproperty.localhost
MYPROPERTY_DOMAIN=myproperty.localhost
LETSENCRYPT_EMAIL=admin@example.com

# ── Public URLs (used by browsers + token issuer) ────────────────
# The proxy terminates TLS, so every browser-facing URL is https.
FRONTEND_PUBLIC_URL=https://app.myproperty.localhost
KEYCLOAK_PUBLIC_URL=https://auth.myproperty.localhost

# Used by keycloak-realm-init to render redirectUris + webOrigins
# into the realm template. Must match FRONTEND_PUBLIC_URL.
MYPROPERTY_FRONTEND_BASE_URL=https://app.myproperty.localhost

# ── Frontend build-time NEXT_PUBLIC_* (baked into the JS bundle) ──
# Changing these requires `docker compose --profile proxy build frontend`
# so the bundle the browser downloads has the new URLs inlined.
NEXT_PUBLIC_API_BASE_URL=https://api.myproperty.localhost
NEXT_PUBLIC_KEYCLOAK_REALM=MyProperty
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=myproperty-frontend

# ── Google OAuth (if exercising Google IdP through the proxy) ────
# Update the authorized redirect URI in Google Cloud Console to:
#   https://auth.myproperty.localhost/realms/MyProperty/broker/google/endpoint
# Otherwise leave the placeholders in .env.example.
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# ── Anthropic + AIOps (unchanged from .env.example) ──────────────
# ANTHROPIC_API_KEY=
# SLACK_WEBHOOK_URL=
# AIOPS_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# AIOPS_LOG_LEVEL=INFO
# AIOPS_CLAUDE_TIMEOUT_SECONDS=15
# AIOPS_SLACK_TIMEOUT_SECONDS=10

# ── Uptime Kuma — proxy-mode overrides (M4.6) ────────────────────
# Status page is now reachable over https through the proxy. The
# Public URL the status page advertises gets overridden so emails
# / Slack messages link to the proxied domain, not the host port.
KUMA_PUBLIC_URL=https://status.myproperty.localhost
# Admin password — same value as in .env.example; restated here so a
# user who only sources .env.proxy.example still gets a working seed.
KUMA_ADMIN_USERNAME=admin
KUMA_ADMIN_PASSWORD=changeme-please-1234
