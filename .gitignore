# =============================================================
#  .gitignore — Full-Stack SaaS (Next.js + .NET 10 + DevOps)
#  LIFE Fellows AI Engineering — Group Project
# =============================================================


# ───────────────────────────────────────────────────────────
#  GENERAL
# ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
*.tmp
*.bak
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace


# ───────────────────────────────────────────────────────────
#  ENVIRONMENT & SECRETS
# ───────────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.p12
*.pfx
*.cer
secrets/
vault/


# ───────────────────────────────────────────────────────────
#  FRONTEND — Next.js / TypeScript / Node
# ───────────────────────────────────────────────────────────
# Dependencies
frontend/node_modules/
node_modules/

# Next.js build output
frontend/.next/
frontend/out/

# Build caches
frontend/.turbo/
frontend/.swc/
frontend/.cache/

# Coverage & test artifacts
frontend/coverage/
frontend/playwright-report/
frontend/test-results/

# Type-check cache
frontend/*.tsbuildinfo
*.tsbuildinfo

# Package manager lock files (keep only one — commit the one you use)
# Uncomment the lock file you do NOT use:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Storybook
frontend/storybook-static/

# Misc
frontend/.eslintcache
frontend/.stylelintcache


# ───────────────────────────────────────────────────────────
#  BACKEND — .NET 10 / C#
# ───────────────────────────────────────────────────────────
# Build outputs
backend/bin/
backend/obj/
**/bin/
**/obj/

# User-specific VS / Rider files
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/
*.DotSettings.user

# Publish output
backend/publish/
**/publish/

# Test results & coverage
backend/TestResults/
**/TestResults/
*.trx
*.coveragexml
coverage.opencover.xml
coverage.cobertura.xml

# Entity Framework migrations snapshot (keep .cs migration files, ignore db state)
# *.Designer.cs  ← don't ignore — EF needs these

# Rider
.idea/

# NuGet
*.nupkg
*.snupkg
**/packages/
!**/packages/build/
nuget.config.local


# ───────────────────────────────────────────────────────────
#  DATABASE
# ───────────────────────────────────────────────────────────
# Local Postgres data volumes (Docker)
postgres-data/
pgdata/
*.sql.bak
*.dump


# ───────────────────────────────────────────────────────────
#  DOCKER & CONTAINERS
# ───────────────────────────────────────────────────────────
# Local Docker volume mounts
volumes/
docker-volumes/
.docker/

# Docker override files (local dev tweaks — not for CI)
docker-compose.override.yml
docker-compose.local.yml


# ───────────────────────────────────────────────────────────
#  KUBERNETES / HELM
# ───────────────────────────────────────────────────────────
# Rendered Helm charts (generated by `helm template`)
infrastructure/k8s/rendered/
infrastructure/helm/rendered/

# kubeconfig (NEVER commit this)
kubeconfig
*.kubeconfig
~/.kube/config


# ───────────────────────────────────────────────────────────
#  TERRAFORM / IaC
# ───────────────────────────────────────────────────────────
infrastructure/.terraform/
**/.terraform/
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfvars
!*.tfvars.example
.terraform.lock.hcl
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json


# ───────────────────────────────────────────────────────────
#  CI/CD — GitHub Actions
# ───────────────────────────────────────────────────────────
# Local act runner cache (.act is a local GH Actions runner)
.act/


# ───────────────────────────────────────────────────────────
#  MONITORING & LOGGING
# ───────────────────────────────────────────────────────────
# Local Loki / Grafana / Prometheus data
loki-data/
grafana-data/
prometheus-data/
elasticsearch-data/
kibana-data/

# Local log files
logs/
*.log


# ───────────────────────────────────────────────────────────
#  REDIS
# ───────────────────────────────────────────────────────────
dump.rdb
redis-data/


# ───────────────────────────────────────────────────────────
#  MESSAGE BROKERS (RabbitMQ / Kafka)
# ───────────────────────────────────────────────────────────
rabbitmq-data/
kafka-data/
zookeeper-data/


# ───────────────────────────────────────────────────────────
#  KEYCLOAK
# ───────────────────────────────────────────────────────────
keycloak-data/
# Realm exports that contain secrets
# (Keep realm config templates, ignore dumps with credentials)
keycloak/exports/


# ───────────────────────────────────────────────────────────
#  FILE UPLOADS / STORAGE
# ───────────────────────────────────────────────────────────
uploads/
tmp-uploads/
storage/


# ───────────────────────────────────────────────────────────
#  AI DEV LOG — docs/ (keep ai-log.md, ignore any raw exports)
# ───────────────────────────────────────────────────────────
docs/ai-log/exports/


# ───────────────────────────────────────────────────────────
#  MISC TOOLS
# ───────────────────────────────────────────────────────────
# Trivy (container scanning)
.trivy/

# Uptime Kuma local data
uptime-kuma-data/

# Playwright browsers (downloaded on CI automatically)
frontend/playwright/.cache/
# ───────────────────────────────────────────────────────────
#  FRONTEND TESTS — build/coverage artifacts
# ───────────────────────────────────────────────────────────
frontend/coverage/
frontend/playwright-report/
frontend/test-results/

# ───────────────────────────────────────────────────────────
#  CLAUDE CODE — per-developer local settings
# ───────────────────────────────────────────────────────────
**/.claude/settings.local.json
