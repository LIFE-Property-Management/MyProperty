      <Content Include="backend\.git\hooks\fsmonitor-watchman.sample" />
      <Content Include="backend\.git\hooks\post-update.sample" />
      <Content Include="backend\.git\hooks\pre-applypatch.sample" />
      <Content Include="backend\.git\hooks\pre-commit.sample" />
      <Content Include="backend\.git\hooks\pre-merge-commit.sample" />
      <Content Include="backend\.git\hooks\pre-push.sample" />
      <Content Include="backend\.git\hooks\pre-rebase.sample" />
      <Content Include="backend\.git\hooks\pre-receive.sample" />
