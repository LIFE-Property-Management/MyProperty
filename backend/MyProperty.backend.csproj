<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
    </PropertyGroup>

    <ItemGroup>
      <None Remove="Properties\launchSettings.json" />
      <None Include="backend\Properties\launchSettings.json" />
    </ItemGroup>

    <ItemGroup>
      <EditorConfigFiles Include="backend\obj\Debug\net10.0\MyProperty.GeneratedMSBuildEditorConfig.editorconfig" />
