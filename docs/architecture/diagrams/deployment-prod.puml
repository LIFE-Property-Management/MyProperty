@startuml
!include <C4/C4_Deployment>

LAYOUT_TOP_DOWN()

title MyProperty Platform - Production deployment (DigitalOcean + Helm + Terraform)

Person(user, "Tenant / Landlord", "browser")
Person(admin, "Admin")
Person(operator, "Operator", "helm via doctl")

Deployment_Node(do, "DigitalOcean (fra1)", "Terraform-provisioned cloud") {

    Deployment_Node(doks, "DOKS Kubernetes cluster", "managed K8s, CNI: Cilium") {

        Deployment_Node(systemNs, "Cluster-system namespaces", "installed once, out-of-chart") {
            Container(ingCtrl,     "ingress-nginx controller", "Deployment in ingress-nginx ns", "Single entry point; obtains certs from cert-manager")
            Container(certManager, "cert-manager",             "Deployment in cert-manager ns", "Issues TLS via Let's Encrypt ClusterIssuer (HTTP-01)")
            Container(esoCtrl,     "External Secrets Operator","Deployment in external-secrets ns", "Optional; reconciles ExternalSecret CRDs")
        }

        Deployment_Node(mpNs, "Namespace: myproperty", "Helm release 'myproperty' 0.1.0") {

            Deployment_Node(appTier, "Application tier") {
                Container(be, "backend",        "Deployment, 1 replica, PVC 5Gi (do-block-storage)", "ghcr.io/.../myproperty-api:{sha} - chiseled .NET 10, UID 1654")
                Container(fe, "frontend",       "Deployment, 2 replicas",                            "ghcr.io/.../myproperty-frontend:{sha} - distroless Node 20")
                Container(aw, "aiops-webhook",  "Deployment, 1 replica",                            "ghcr.io/.../myproperty-aiops-webhook:{sha}")
                Container(migJob, "migration-job", "pre-upgrade Helm Hook Job",                       "EF Core migration bundle - ghcr.io/.../myproperty-migrations:{sha}")
            }

            Deployment_Node(dataTier, "Data tier") {
                ContainerDb(pg,  "postgres",  "StatefulSet + PVC 10Gi (in-cluster) OR DO Managed Postgres (when postgres.enabled=false)", "App + Hangfire + Keycloak schemas; toggle via values.yaml")
                ContainerDb(rds, "redis",     "Deployment, ephemeral",                              "Cache + SignalR backplane")
                ContainerQueue(rmq, "rabbitmq", "StatefulSet + PVC 5Gi",                            "Topic exchange 'myproperty.events'")
                Container(kc,    "keycloak",  "Deployment + alpine realm-init initContainer + ConfigMap", "OIDC IdP, realm import via ConfigMap")
            }

            Deployment_Node(obs, "Observability (Helm dep: kube-prometheus-stack 65.2.0)") {
                Container(prom,  "prometheus",    "Operator-managed StatefulSet + PVC 20Gi", "15d retention; reads ServiceMonitors")
                Container(am,    "alertmanager",  "Operator-managed + PVC 1Gi",              "Routes -> aiops-webhook ClusterIP")
                Container(graf,  "grafana",       "Deployment + PVC 2Gi",                    "Secret-backed admin; dashboards via sidecar")
                Container(loki,  "loki",          "StatefulSet + PVC 10Gi",                  "Log store")
                Container(ptail, "promtail",      "DaemonSet (1 pod per node, with RBAC)",   "Tails /var/log/pods/*")
                Container(uk,    "uptime-kuma",   "StatefulSet + PVC 2Gi + seed Job",        "External HTTPS probes + status page")
            }

            Deployment_Node(crd, "K8s objects (chart-rendered)") {
                Container(ingApi,    "api-ingress",         "Ingress", "api.X -> backend:8080")
                Container(ingFe,     "frontend-ingress",    "Ingress", "app.X -> frontend:3000")
                Container(ingAuth,   "keycloak-ingress",    "Ingress", "auth.X -> keycloak:8080")
                Container(ingStatus, "uptime-kuma-ingress", "Ingress", "status.X -> uptime-kuma:3001")
                Container(svcMon,    "api ServiceMonitor + PrometheusRule", "CRDs", "/metrics scrape + alert rules")
                Container(extSec,    "13x ExternalSecret + SecretStore", "ESO CRDs (optional)", "Postgres / RabbitMQ / Keycloak / OAuth / Anthropic / Grafana / Discord")
                Container(netPol,    "NetworkPolicies", "default-deny + targeted-allow (optional)", "Enforced by Cilium")
            }
        }
    }

    ContainerDb(doPg, "DO Managed PostgreSQL 16", "alternative to in-cluster", "Reads creds from myproperty-postgres Secret")
    Container_Ext(spaces, "DO Spaces bucket", "S3-compatible (private ACL)", "Receipts; bucket-scoped key")
}

' ====== External (off-DO) ======
System_Ext(le,    "Let's Encrypt",      "ACME v2 CA")
System_Ext(ghcr,  "GHCR",                "ghcr.io/life-property-management/*")
System_Ext(anth,  "Anthropic API",       "Claude vision + Haiku")
System_Ext(slack, "Slack",               "Incoming webhook")
System_Ext(gcp,   "GCP Secret Manager",  "Optional ESO backend")
System_Ext(az,    "Azure Key Vault",     "Optional ESO backend (alternative)")
System_Ext(gh,    "GitHub Actions",      "CD workflow: doctl + helm upgrade --atomic")

' ====== User / operator traffic ======
Rel(user, ingCtrl, "HTTPS to 4 hosts", "app/api/auth + browse")
Rel(admin, ingCtrl, "HTTPS to api.X/hangfire + auth.X (realm admin)", "")
Rel(operator, doks, "helm upgrade --install", "via doctl + kubeconfig")
Rel(gh, doks, "CD on push to main/develop", "doctl + helm")

' ====== Ingress -> workloads ======
Rel(ingCtrl, fe,  "Routes app.X")
Rel(ingCtrl, be,  "Routes api.X")
Rel(ingCtrl, kc,  "Routes auth.X")
Rel(ingCtrl, uk,  "Routes status.X")
Rel(ingCtrl, certManager, "Request certs (annotation-driven)")
Rel(certManager, le, "ACME HTTP-01", "HTTPS")

' ====== Workloads -> data ======
Rel(be, pg,   "Npgsql (in-cluster)", "TCP")
Rel(be, doPg, "Npgsql (managed mode)", "TCP")
Rel(be, rds,  "StackExchange.Redis", "TCP")
Rel(be, rmq,  "AMQP", "TCP")
Rel(be, kc,   "JWKS", "in-cluster HTTP")
Rel(be, spaces, "Receipts (S3 PUT/GET)", "HTTPS")
Rel(be, anth, "Receipt OCR", "HTTPS")
Rel(kc, pg,   "Realm DB")

' ====== Migration job ======
Rel(migJob, pg, "EF Core migrations (pre-upgrade Helm Hook)", "")

' ====== Observability ======
Rel(prom, svcMon, "Reads scrape config")
Rel(prom, be,   "Scrape /metrics")
Rel(prom, am,   "Fire alerts")
Rel(am,   aw,   "Webhook")
Rel(aw,   anth, "Triage")
Rel(aw,   slack, "Notify")
Rel(ptail, loki, "Push pod logs")
Rel(graf, prom, "Query metrics")
Rel(graf, loki, "Query logs")
Rel(graf, am,   "Alert state")
Rel(uk,   ingCtrl, "Probe app/api/auth.X", "HTTPS")

' ====== Image pulls ======
Rel(doks, ghcr, "Pull container images", "HTTPS")

' ====== External Secrets ======
Rel(esoCtrl, extSec, "Reconcile -> K8s Secret")
Rel(extSec, gcp,  "Pull when provider=gcp", "HTTPS")
Rel(extSec, az,   "Pull when provider=azure", "HTTPS")

@enduml
