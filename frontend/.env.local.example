# =============================================================
#  Frontend environment variables (Next.js build-time)
# =============================================================
# Copy this file to .env.local (gitignored) and fill in values.
# All NEXT_PUBLIC_* vars are exposed to the browser bundle.

# ── Keycloak ────────────────────────────────────────────────
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=MyProperty
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=myproperty-frontend  # matches clientId in infrastructure/keycloak/realm-export.json

# ── API ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:5042

# ── Dev-only auth bypass ────────────────────────────────────
# Set to "true" to skip Keycloak init and sign in as a fixture identity.
# Only for local UI work without a running Keycloak. Must be unset (or "false")
# in any deployed environment. KeycloakInit emits a console.warn if true in prod.
# NEXT_PUBLIC_DEV_AUTH_BYPASS=true
