# =============================================================
#  Frontend environment variables (Next.js — BUILD TIME)
# =============================================================
# Copy this file to .env.local (gitignored) and fill in values.
#
# IMPORTANT: All NEXT_PUBLIC_* vars are inlined into the browser bundle
# at `next build` time, not read at runtime. To change them in a deployed
# environment, you must rebuild the image with new --build-arg values.
#
# For Docker builds, these are passed as:
#   docker build \
#     --build-arg NEXT_PUBLIC_API_BASE_URL=https://api.myproperty.PLACEHOLDER.example \
#     --build-arg NEXT_PUBLIC_KEYCLOAK_URL=https://auth.myproperty.PLACEHOLDER.example \
#     --build-arg NEXT_PUBLIC_KEYCLOAK_REALM=MyProperty \
#     --build-arg NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=myproperty-frontend \
#     -f frontend/Dockerfile frontend/

# ── Keycloak ────────────────────────────────────────────────
# Dev: localhost Keycloak from docker-compose.
# Prod: publicly-resolvable hostname (the browser hits this URL directly).
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
# Prod example: NEXT_PUBLIC_KEYCLOAK_URL=https://auth.myproperty.PLACEHOLDER.example

NEXT_PUBLIC_KEYCLOAK_REALM=MyProperty
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=myproperty-frontend  # matches clientId in infrastructure/keycloak/realm-export.json

# ── API ─────────────────────────────────────────────────────
# Dev: leave UNSET so axios uses relative URLs and MSW intercepts.
#      Setting this in dev bypasses MSW entirely (see handlers.ts).
# Prod: REQUIRED. Without it, the production build throws at module load.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:5042
# Prod example: NEXT_PUBLIC_API_BASE_URL=https://api.myproperty.PLACEHOLDER.example

# ── Dev-only auth bypass ────────────────────────────────────
# Set to "true" to skip Keycloak init and sign in as a fixture identity.
# Only for local UI work without a running Keycloak. MUST be unset (or "false")
# in any deployed environment. KeycloakInit emits a console.warn if true in
# a production build.
#
# This file must never enter a production Docker build context.
# See frontend/.dockerignore.
# NEXT_PUBLIC_DEV_AUTH_BYPASS=true
