      "pluginVersion": "11.1.0",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "100 * (sum(rate(http_requests_received_total{job=\"myproperty-api\", code=~\"5..\"}[5m])) or vector(0)) / clamp_min(sum(rate(http_requests_received_total{job=\"myproperty-api\"}[5m])), 0.0001)", "legendFormat": "5xx %", "refId": "A" }
      ],
      "title": "Error rate (5xx)",
      "description": "Percent of requests returning a 5xx (server error). Threshold mirrors alerts/api.yml MyPropertyApiHighErrorRate (>5% for 5m). 4xx is excluded — those are client errors, not server faults.",
      "type": "stat"
    },
