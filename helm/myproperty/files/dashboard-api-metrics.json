      "pluginVersion": "11.1.0",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "sum(rate(http_requests_received_total{job=\"myproperty-api\"}[5m]))", "legendFormat": "req/s", "refId": "A" }
      ],
      "title": "Request rate",
      "description": "Requests per second the API is currently serving (averaged over 5m). Your overall traffic level — compare against latency and errors to judge load.",
      "type": "stat"
    },
