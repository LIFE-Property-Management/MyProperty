      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "mailpit_messages", "legendFormat": "stored", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "mailpit_messages_unread", "legendFormat": "unread", "refId": "B" }
