  "description": "Mailpit — the cluster SMTP endpoint that captures every outbound email (invites, password resets, payment confirmations) and relays each one to Resend for real delivery. Metrics come from Mailpit's Prometheus exporter; the bottom panel shows its live logs from Loki.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "text",
      "id": 1,
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "## Mailpit — Email Delivery\nMailpit is the single SMTP endpoint for the cluster. The backend and Keycloak send mail to it on port 1025; Mailpit **captures a viewable copy** and **relays every message to Resend** for real delivery.\n\n- **Top row** = at-a-glance health. *Status* must be **UP** or no email is being sent at all.\n- **Throughput** = how much mail is flowing and whether any is being rejected.\n- **Storage** = retained messages (capped at 5000) and disk/memory use.\n- **Logs** (bottom) = Mailpit's own output. ⚠️ *Successful relays to Resend are silent* — only **relay errors** appear here, so a quiet log + UP status = healthy. Check the Resend dashboard for per-message delivery."
      }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red", "index": 1 } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green", "index": 0 } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 4 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.1.0",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "up{job=\"mailpit\"}", "legendFormat": "status", "refId": "A" }
      ],
      "title": "Status",
      "description": "Is Mailpit being scraped successfully? DOWN means Prometheus can't reach it — treat as 'email is probably failing'. Mirrors the MailpitDown alert.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 4 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.1.0",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "mailpit_smtp_accepted_total", "legendFormat": "accepted", "refId": "A" }
      ],
      "title": "Emails accepted (since start)",
      "description": "Total messages Mailpit has accepted on SMTP since it last started. Counts every invite / reset / confirmation handed to it. Resets to 0 on restart.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 4 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.1.0",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "mailpit_smtp_rejected_total", "legendFormat": "rejected", "refId": "A" }
      ],
      "title": "Emails rejected (since start)",
      "description": "Messages Mailpit refused at its own SMTP door (malformed / oversized). Should stay 0 — anything above means a sender (backend/Keycloak) is producing mail Mailpit won't accept.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 4000 }, { "color": "red", "value": 5000 } ] },
          "unit": "short",
          "max": 5000
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 4 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.1.0",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "mailpit_messages", "legendFormat": "stored", "refId": "A" }
      ],
      "title": "Messages stored (cap 5000)",
      "description": "Captured messages currently held on the PVC. Capped by MP_MAX_MESSAGES=5000 — Mailpit prunes the oldest beyond that, so this plateauing near 5000 is expected, not a leak.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
