        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.1.0",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "rate(mailpit_smtp_accepted_total[5m])", "legendFormat": "accepted/s", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "rate(mailpit_smtp_rejected_total[5m])", "legendFormat": "rejected/s", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "rate(mailpit_smtp_ignored_total[5m])", "legendFormat": "ignored (dupes)/s", "refId": "C" }
      ],
      "title": "SMTP throughput",
      "description": "Per-second rate of messages accepted, rejected, and ignored (duplicates) over a 5m window. 'accepted' tracks real send activity; sustained 'rejected' is the signal something upstream is malformed.",
      "type": "timeseries"
    },
