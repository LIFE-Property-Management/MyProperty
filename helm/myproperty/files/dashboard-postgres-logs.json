      "options": {
        "mode": "markdown",
        "content": "## PostgreSQL — Database\nThe primary datastore (EF Core, Hangfire job storage). **Look here when:** the API returns 5xx errors, requests get slow, or migrations fail on deploy. Common red flags: `FATAL: connection ... refused`, `too many clients already`, `could not serialize access`, checkpoint warnings. Postgres logs plain text — the panels use text matching, not a structured `level`."
      }
    },
    {
      "type": "stat", "id": 2, "title": "Total log lines (range)",
      "description": "All PostgreSQL lines over the selected time range.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 3 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "unit": "short" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [ { "datasource": { "type": "loki", "uid": "loki" }, "editorMode": "code", "expr": "sum(count_over_time({namespace=\"project-02\", component=\"postgres\"} [$__range]))", "queryType": "instant", "refId": "A" } ]
    },
    {
      "type": "stat", "id": 3, "title": "Errors & fatals (range)",
      "description": "Lines matching error/fatal/panic/warning. Red when any are present.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 3 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [ { "datasource": { "type": "loki", "uid": "loki" }, "editorMode": "code", "expr": "sum(count_over_time({namespace=\"project-02\", component=\"postgres\"} |~ \"(?i)error|fatal|panic|warning\" [$__range]))", "queryType": "instant", "refId": "A" } ]
    },
    {
      "type": "timeseries", "id": 4, "title": "Log volume over time",
      "description": "Lines per bucket. A flat-zero stretch means Postgres restarted or went idle.",
