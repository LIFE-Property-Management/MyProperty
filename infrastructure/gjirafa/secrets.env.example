# Copy to .secrets.env (gitignored) and replace the placeholder values below.
# Quote values. Passwords for postgres/rabbitmq/keycloak-admin are NOT here —
# secrets.sh generates and appends them on first run.

# --- GitHub Container Registry pull secret ---
GHCR_USERNAME="your-github-username"
GHCR_PAT="ghp_replace_with_a_read_packages_token"

# --- Google OAuth (Keycloak Google identity provider) ---
GOOGLE_CLIENT_ID="replace-with-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-oauth-client-secret"

# --- Anthropic API key (backend receipt-OCR / AIOps) ---
ANTHROPIC_API_KEY="sk-ant-replace-me"

# --- Discord webhook URL (Alertmanager → AIOps → Discord alerts) ---
# Create at: Discord server settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/replace-with-your-webhook-url"

# --- Discord webhook URL for Uptime Kuma (separate channel, e.g. #uptime) ---
# Optional: leave empty to disable Kuma's Discord channel (it degrades cleanly).
# Use a DIFFERENT webhook/channel from DISCORD_WEBHOOK_URL so black-box uptime
# checks and Prometheus/AIOps triage don't share one feed.
DISCORD_UPTIME_WEBHOOK_URL=""

# --- Optional identifier overrides (defaults shown; uncomment to change) ---
# POSTGRES_USER="myproperty"
# POSTGRES_DB="myproperty"
# RABBITMQ_USER="myproperty"
# KEYCLOAK_ADMIN_USER="admin"
